ENVIRONMENT=development
# Local Postgres + Redis run via `docker compose up -d` (see docker-compose.yml).
DATABASE_URL=postgresql://postgres@localhost:5432/swimcoach
SECRET_KEY=change-me-to-a-long-random-value
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Optional - unset to fall back to in-process memory (what the test suite does).
REDIS_URL=redis://localhost:6379
LOGIN_RATE_LIMIT_PER_EMAIL=5/5minutes
LOGIN_RATE_LIMIT_PER_IP=20/5minutes
REGISTER_RATE_LIMIT_PER_IP=5/hour
